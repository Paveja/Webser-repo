    "MyDBSubnetGroup": {
      "Type": "AWS::RDS::DBSubnetGroup",
      "Properties": {
        "DBSubnetGroupName": "outside-harlequin-stingray-db-subnet-group",
        "DBSubnetGroupDescription": "Subnet group for RDS",
        "SubnetIds": [
          {
            "Ref": "PrivateSubnet1"
          },
          {
            "Ref": "PrivateSubnet2"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "outside-harlequin-stingray-db-subnet-group"
          }
        ]
      }
    },
    "ECSLaunchTemplate": {
      "Type": "AWS::EC2::LaunchTemplate",
      "DependsOn": "ECSCluster",
      "Properties": {
        "LaunchTemplateData": {
          "ImageId": {
            "Ref": "LatestECSOptimizedAMI"
          },
          "NetworkInterfaces": [
            {
              "AssociatePublicIpAddress": true,
              "DeviceIndex": 0,
              "DeleteOnTermination": true,
              "Groups": [
                {
                  "Fn::GetAtt": [
                    "Ec2SecurityGroup",
                    "GroupId"
                  ]
                }
              ]
            }
          ],
          "KeyName": "ecs-cluster",
          "IamInstanceProfile": {
            "Arn": {
              "Ref": "IamRoleInstanceProfile"
            }
          },
          "UserData": {
            "Fn::Base64": {
              "Fn::Join": [
                "",
                [
                  "#!/bin/bash\n",
                  "echo ECS_CLUSTER=",
                  {
                    "Ref": "ECSClusterName"
                  },
                  " >> /etc/ecs/ecs.config\n",
                  "yum install -y -q aws-cli jq amazon-cloudwatch-agent\n",
                  "cat <<'EOF' > /usr/local/bin/dynamic-cloudwatch.sh\n",
                  "#!/bin/bash\n",
                  "generate_config() {\n",
                  "  local insights_json=\"$1\"\n",
                  "  local config_file=\"/opt/aws/amazon-cloudwatch-agent/bin/config.json\"\n",
                  "  echo '{\n",
                  "  \"metrics\": {\n",
                  "    \"namespace\": \"EC2/MemoryAndDisk\",\n",
                  "    \"append_dimensions\": {\n",
                  "      \"InstanceId\": \"${aws:InstanceId}\"\n",
                  "    },\n",
                  "    \"aggregation_dimensions\": [[\"InstanceId\"]],\n",
                  "    \"metrics_collected\": {' > \"$config_file\"\n",
                  "  local types_with_resources=(\"cpu\" \"disk\" \"diskio\")\n",
                  "  local keys=($(echo \"$insights_json\" | jq -r 'keys[]'))\n",
                  "  local total=${#keys[@]}\n",
                  "  for i in \"${!keys[@]}\"; do\n",
                  "    local key=\"${keys[$i]}\"\n",
                  "    local measurements=$(echo \"$insights_json\" | jq -c --arg k \"$key\" '.[$k]')\n",
                  "    echo \"      \\\"$key\\\": {\" >> \"$config_file\"\n",
                  "    echo \"        \\\"measurement\\\": [\" >> \"$config_file\"\n",
                  "    echo \"$measurements\" | jq -r '.[] | \"          \\\"\" + . + \"\\\",\"' >> \"$config_file\"\n",
                  "    sed -i '$ s/,$//' \"$config_file\"\n",
                  "    echo \"        ],\" >> \"$config_file\"\n",
                  "    echo \"        \\\"metrics_collection_interval\\\": 300\" >> \"$config_file\"\n",
                  "    if [[ \" ${types_with_resources[@]} \" =~ \" $key \" ]]; then\n",
                  "      echo \"        ,\\\"resources\\\": [\\\"*\\\"]\" >> \"$config_file\"\n",
                  "      echo \"        ,\\\"aggregation_dimensions\\\": [[\\\"InstanceId\\\"]]\" >> \"$config_file\"\n",
                  "    fi\n",
                  "    if [[ \"$i\" -lt $((total - 1)) ]]; then\n",
                  "      echo \"      },\" >> \"$config_file\"\n",
                  "    else\n",
                  "      echo \"      }\" >> \"$config_file\"\n",
                  "    fi\n",
                  "  done\n",
                  "  echo '    }\n",
                  "  }\n",
                  "}' >> \"$config_file\"\n",
                  "}\n",
                  "# Main execution\n",
                  "echo \"[INFO] Starting dynamic-cloudwatch.sh at $(date)\" >> /var/log/dynamic-cloudwatch.log\n",
                  "task_json=$(curl -s http://localhost:51678/v1/tasks 2>/dev/null)\n",
                  "echo \"[DEBUG] ECS task metadata: $task_json\" >> /var/log/dynamic-cloudwatch.log\n",
                  "if [[ -n \"$task_json\" && \"$task_json\" != \"null\" ]]; then\n",
                  "  docker_id=$(echo \"$task_json\" | jq -r '.Tasks[0].Containers[0].DockerId' 2>/dev/null)\n",
                  "  echo \"[DEBUG] Extracted Docker ID: $docker_id\" >> /var/log/dynamic-cloudwatch.log\n",
                  "  \n",
                  "  if [[ -n \"$docker_id\" && \"$docker_id\" != \"null\" ]]; then\n",
                  "    crontab -l | grep -v '/usr/local/bin/dynamic-cloudwatch.sh' | crontab -\n",
                  "    container_env=$(docker exec \"$docker_id\" env 2>&1)\n",
                  "    echo \"[DEBUG] Container env output:\" >> /var/log/dynamic-cloudwatch.log\n",
                  "    echo \"$container_env\" >> /var/log/dynamic-cloudwatch.log\n",
                  "    \n",
                  "    insights=$(echo \"$container_env\" | grep '^insights=' | cut -d= -f2- | head -1)\n",
                  "    echo \"[DEBUG] Raw 'insights' value: $insights\" >> /var/log/dynamic-cloudwatch.log\n",
                  "    \n",
                  "    if [[ -n \"$insights\" ]] && echo \"$insights\" | jq . >/dev/null 2>&1; then\n",
                  "      echo \"[INFO] Valid 'insights' JSON found.\" >> /var/log/dynamic-cloudwatch.log\n",
                  "      generate_config \"$insights\"\n",
                  "    else\n",
                  "      echo \"[WARN] 'insights' is not valid JSON or is empty. Using fallback.\" >> /var/log/dynamic-cloudwatch.log\n",
                  "      generate_config '{\"mem\": [\"mem_used\"], \"diskio\": [\"read_bytes\", \"write_bytes\"]}'\n",
                  "    fi\n",
                  "else\n",
                  "  echo \"[WARN] ECS task metadata not found. Will retry in next cron cycle.\" >> /var/log/dynamic-cloudwatch.log\n",
                  "  exit 0\n",
                  "fi\n",
                  "else\n",
                  "  echo \"[WARN] ECS task metadata not found. Will retry in next cron cycle.\" >> /var/log/dynamic-cloudwatch.log\n",
                  "  exit 0\n",
                  "fi\n",
                  "/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \\\n",
                  "  -a fetch-config -m ec2 \\\n",
                  "  -c file:/opt/aws/amazon-cloudwatch-agent/bin/config.json -s >> /var/log/dynamic-cloudwatch.log 2>&1\n",
                  "  \n",
                  "echo \"[INFO] Finished dynamic-cloudwatch.sh at $(date)\" >> /var/log/dynamic-cloudwatch.log\n",
                  "EOF\n",
                  "chmod +x /usr/local/bin/dynamic-cloudwatch.sh\n",
                  "echo '*/5 * * * * /usr/local/bin/dynamic-cloudwatch.sh >> /var/log/dynamic-cloudwatch.log 2>&1' | sudo crontab -"
                ]
              ]
            }
          }
        }
      }
    },
    "ECSCluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": {
          "Ref": "ECSClusterName"
        },
        "ClusterSettings": [
          {
            "Name": "containerInsights",
            "Value": "disabled"
          }
        ],
        "ServiceConnectDefaults": {
          "Namespace": "dev-cluster"
        },
        "Tags": [
          {
            "Key": "name",
            "Value": "outside-harlequin-stingray-cluster"
          }
        ]
      }
    },
    "Ec2SecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Created in ECS Console",
        "GroupName": "outside-harlequin-stingray-cluster-instance-sg",
        "VpcId": {
          "Ref": "VPC"
        },
        "SecurityGroupIngress": [
          {
            "FromPort": 80,
            "ToPort": 80,
            "IpProtocol": "tcp",
            "CidrIp": "0.0.0.0/0"
          },
          {
            "FromPort": 443,
            "ToPort": 443,
            "IpProtocol": "tcp",
            "CidrIp": "0.0.0.0/0"
          },
          {
            "FromPort": 8080,
            "ToPort": 8080,
            "IpProtocol": "tcp",
            "CidrIp": "0.0.0.0/0"
          },
          {
            "FromPort": 22,
            "ToPort": 22,
            "IpProtocol": "tcp",
            "CidrIp": "0.0.0.0/0"
          }
        ]
      }
    },
    "StrikeqaPrivateNamespace": {
      "Type": "AWS::ServiceDiscovery::PrivateDnsNamespace",
      "Properties": {
        "Name": "Strike.qa.local",
        "Vpc": {
          "Ref": "VPC"
        }
      }
    },
    "StrikeqaVpcLink": {
      "Type": "AWS::ApiGatewayV2::VpcLink",
      "Properties": {
        "Name": "Strike-qa-vpc-link",
        "SubnetIds": [
          {
            "Ref": "PublicSubnet1"
          },
          {
            "Ref": "PublicSubnet2"
          },
          {
            "Ref": "PrivateSubnet1"
          },
          {
            "Ref": "PrivateSubnet2"
          }
        ],
        "SecurityGroupIds": [
          {
            "Ref": "Ec2SecurityGroup"
          }
        ]
      }
    },
    "StrikeqasocketCertificateManager": {
      "Type": "Custom::RequestACMCertificate",
      "Properties": {
        "ServiceToken": "arn:aws:sns:us-west-1:120569605035:120569605035-cloudformation",
        "DomainName": "a184aac325aa.account-1.poddleops.com",
        "ValidationMethod": "DNS",
        "ValidationDomain": "poddleops.com",
        "AccountId": "120569605035",
        "HostedZoneId": "Z0892304OQTFZ4ZOLMU0",
        "Tags": [
          {
            "Key": "environment",
            "Value": ":p=Strike:a=Knight:e=qa:b=main"
          }
        ],
        "Region": "us-west-1",
        "RoleArn": "arn:aws:iam::120569605035:role/OrganizationAccountAccessRole"
      }
    },
    "StrikeqasocketCustomDomain": {
      "Type": "AWS::ApiGatewayV2::DomainName",
      "DependsOn": [
        "StrikeqasocketCertificateManager"
      ],
      "Properties": {
        "DomainName": "a184aac325aa.account-1.poddleops.com",
        "DomainNameConfigurations": [
          {
            "CertificateArn": {
              "Ref": "StrikeqasocketCertificateManager"
            },
            "EndpointType": "REGIONAL"
          }
        ]
      }
    },
    "StrikeqasocketApiGateway": {
      "Type": "AWS::ApiGatewayV2::Api",
      "Properties": {
        "Name": "Strike-qa-socket-gateway",
        "ProtocolType": "WEBSOCKET",
        "RouteSelectionExpression": "$request.body.action"
      }
    },
    "StrikeqasocketStage": {
      "Type": "AWS::ApiGatewayV2::Stage",
      "DependsOn": "StrikeqasocketApiGateway",
      "Properties": {
        "ApiId": {
          "Ref": "StrikeqasocketApiGateway"
        },
        "StageName": "$default",
        "AutoDeploy": true
      }
    },
    "StrikeqasocketCustomDomainMapping": {
      "Type": "AWS::ApiGatewayV2::ApiMapping",
      "DependsOn": [
        "StrikeqasocketApiGateway",
        "StrikeqasocketCustomDomain",
        "StrikeqasocketStage"
      ],
      "Properties": {
        "ApiId": {
          "Ref": "StrikeqasocketApiGateway"
        },
        "DomainName": {
          "Ref": "StrikeqasocketCustomDomain"
        },
        "Stage": {
          "Ref": "StrikeqasocketStage"
        }
      }
    },
    "StrikeqasocketAliasRecord": {
      "Type": "AWS::Route53::RecordSet",
      "DependsOn": [
        "StrikeqasocketCustomDomain"
      ],
      "Properties": {
        "HostedZoneId": "Z0892304OQTFZ4ZOLMU0",
        "Name": "a184aac325aa.account-1.poddleops.com",
        "Type": "A",
        "AliasTarget": {
          "HostedZoneId": {
            "Fn::GetAtt": [
              "StrikeqasocketCustomDomain",
              "RegionalHostedZoneId"
            ]
          },
          "DNSName": {
            "Fn::GetAtt": [
              "StrikeqasocketCustomDomain",
              "RegionalDomainName"
            ]
          }
        }
      }
    },
    "Knightqarid1TaskDefinition": {
      "Type": "AWS::ECS::TaskDefinition",
      "Properties": {
        "Family": "Knightqarid1-td",
        "Cpu": "1800",
        "Memory": "1800",
        "NetworkMode": "bridge",
        "RequiresCompatibilities": [
          "EC2"
        ],
        "ContainerDefinitions": [
          {
            "Image": "120569605035.dkr.ecr.us-west-2.amazonaws.com/strike-knight-qa-rid_1:V3",
            "Environment": [
              {
                "Name": "BASE_URL",
                "Value": "/api/v1"
              },
              {
                "Name": "insights",
                "Value": "{\"diskio\":[\"read_bytes\",\"write_bytes\"],\"mem\":[\"mem_used\"]}"
              }
            ],
            "logConfiguration": {
              "logDriver": "awslogs",
              "options": {
                "awslogs-group": "strike-knightqa",
                "awslogs-region": "us-west-1",
                "awslogs-stream-prefix": "strike-knightqa-container-logs"
              }
            },
            "Name": "Knightqarid1-container",
            "Cpu": 1800,
            "Memory": 1800,
            "MemoryReservation": 1700,
            "healthCheck": {
              "command": [
                "CMD-SHELL",
                "exit 0"
              ],
              "interval": 10,
              "timeout": 5,
              "retries": 1,
              "startPeriod": 5
            },
            "Essential": true,
            "PortMappings": [
              {
                "ContainerPort": 8080,
                "HostPort": 8080,
                "Protocol": "tcp",
                "Name": "strike-qa-port"
              }
            ]
          }
        ],
        "TaskRoleArn": "arn:aws:iam::120569605035:role/OrganizationAccountAccessRole",
        "ExecutionRoleArn": "arn:aws:iam::120569605035:role/OrganizationAccountAccessRole",
        "Tags": [
          {
            "Key": "environment",
            "Value": ":p=Strike:a=Knight:e=qa:b=main"
          }
        ]
      }
    },
    "Knightqarid1ServiceDiscovery": {
      "Type": "AWS::ServiceDiscovery::Service",
      "Properties": {
        "Name": "Knight-service",
        "NamespaceId": {
          "Ref": "StrikeqaPrivateNamespace"
        },
        "DnsConfig": {
          "NamespaceId": {
            "Ref": "StrikeqaPrivateNamespace"
          },
          "RoutingPolicy": "MULTIVALUE",
          "DnsRecords": [
            {
              "Type": "SRV",
              "TTL": 15
            }
          ]
        },
        "HealthCheckCustomConfig": {
          "FailureThreshold": 3
        }
      }
    },
    "Knightqarid1ECSService": {
      "Type": "AWS::ECS::Service",
      "DependsOn": [
        "ECSCluster",
        "Knightqarid1TaskDefinition",
        "Knightqarid1ServiceDiscovery"
      ],
      "Properties": {
        "Cluster": {
          "Ref": "ECSClusterName"
        },
        "TaskDefinition": {
          "Ref": "Knightqarid1TaskDefinition"
        },
        "ServiceName": "Knightqarid1-service",
        "SchedulingStrategy": "REPLICA",
        "DesiredCount": 1,
        "CapacityProviderStrategy": [
          {
            "CapacityProvider": "CapacityProviderT3SmallStrikeqa",
            "Base": 0,
            "Weight": 1
          }
        ],
        "HealthCheckGracePeriodSeconds": 120,
        "DeploymentConfiguration": {
          "MaximumPercent": 200,
          "MinimumHealthyPercent": 100,
          "DeploymentCircuitBreaker": {
            "Enable": true,
            "Rollback": true
          }
        },
        "DeploymentController": {
          "Type": "ECS"
        },
        "ServiceRegistries": [
          {
            "RegistryArn": {
              "Fn::GetAtt": [
                "Knightqarid1ServiceDiscovery",
                "Arn"
              ]
            },
            "ContainerName": "Knightqarid1-container",
            "ContainerPort": 8080
          }
        ],
        "PlacementStrategies": [
          {
            "Field": "attribute:ecs.availability-zone",
            "Type": "spread"
          },
          {
            "Field": "instanceId",
            "Type": "spread"
          }
        ],
        "PlacementConstraints": [],
        "Tags": [
          {
            "Key": "environment",
            "Value": ":p=Strike:a=Knight:e=qa:b=main"
          }
        ],
        "EnableECSManagedTags": true
      }
    },
    "Knightqarid1ServiceIntegration": {
      "Type": "AWS::ApiGatewayV2::Integration",
      "DependsOn": "Knightqarid1ECSService",
      "Properties": {
        "ApiId": {
          "Ref": "StrikeqasocketApiGateway"
        },
        "IntegrationType": "AWS_PROXY",
        "IntegrationUri": {
          "Fn::GetAtt": [
            "Knightqarid1ServiceDiscovery",
            "Arn"
          ]
        },
        "IntegrationMethod": "ANY",
        "ConnectionType": "VPC_LINK",
        "ConnectionId": {
          "Ref": "StrikeqaVpcLink"
        },
        "PayloadFormatVersion": "1.0"
      }
    },
    "Knightqarid1GatewayRoute": {
      "Type": "AWS::ApiGatewayV2::Route",
      "DependsOn": "Knightqarid1ServiceIntegration",
      "Properties": {
        "ApiId": {
          "Ref": "StrikeqasocketApiGateway"
        },
        "RouteKey": "$default",
        "Target": {
          "Fn::Join": [
            "/",
            [
              "integrations",
              {
                "Ref": "Knightqarid1ServiceIntegration"
              }
            ]
          ]
        }
      }
    },
    "ECSAutoScalingGroupT3SmallStrikeqa": {
      "Type": "AWS::AutoScaling::AutoScalingGroup",
      "Properties": {
        "MinSize": 1,
        "MaxSize": 2,
        "DesiredCapacity": 1,
        "MixedInstancesPolicy": {
          "LaunchTemplate": {
            "LaunchTemplateSpecification": {
              "LaunchTemplateId": {
                "Ref": "ECSLaunchTemplate"
              },
              "Version": {
                "Fn::GetAtt": [
                  "ECSLaunchTemplate",
                  "LatestVersionNumber"
                ]
              }
            },
            "Overrides": [
              {
                "InstanceType": "t3.small"
              }
            ]
          },
          "InstancesDistribution": {
            "OnDemandBaseCapacity": 0,
            "OnDemandPercentageAboveBaseCapacity": 0,
            "SpotAllocationStrategy": "lowest-price"
          }
        },
        "VPCZoneIdentifier": [
          {
            "Ref": "PublicSubnet1"
          },
          {
            "Ref": "PublicSubnet2"
          }
        ],
        "Tags": [
          {
            "Key": "environment",
            "Value": ":os=alpha",
            "PropagateAtLaunch": true
          }
        ]
      },
      "DependsOn": [
        "ECSCluster",
        "ECSLaunchTemplate",
        "PublicSubnet1",
        "PublicSubnet2"
      ],
      "UpdatePolicy": {
        "AutoScalingRollingUpdate": {
          "MinInstancesInService": 0,
          "MaxBatchSize": 1,
          "PauseTime": "PT2M"
        }
      }
    },
    "CapacityProviderT3SmallStrikeqa": {
      "Type": "AWS::ECS::CapacityProvider",
      "Properties": {
        "Name": "CapacityProviderT3SmallStrikeqa",
        "AutoScalingGroupProvider": {
          "AutoScalingGroupArn": {
            "Ref": "ECSAutoScalingGroupT3SmallStrikeqa"
          },
          "ManagedScaling": {
            "Status": "ENABLED",
            "TargetCapacity": 100
          },
          "ManagedTerminationProtection": "DISABLED"
        }
      },
      "DependsOn": [
        "ECSAutoScalingGroupT3SmallStrikeqa"
      ]
    },
    "ClusterCPAssociation": {
      "Type": "AWS::ECS::ClusterCapacityProviderAssociations",
      "Properties": {
        "Cluster": {
          "Ref": "ECSClusterName"
        },
